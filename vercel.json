{
  "version": 2,
  "name": "pesaskill-frontend",
  "buildCommand": "cd pesaskill/frontend && npm install && npm run build",
  "outputDirectory": "pesaskill/frontend/dist",
  "installCommand": "cd pesaskill/frontend && npm install",
  "framework": null,
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
